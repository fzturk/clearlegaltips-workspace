{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NonInteractive -Command \"$json = [Console]::In.ReadToEnd(); if ($json) { $fp = ($json | ConvertFrom-Json).tool_input.file_path; if ($fp -and $fp.EndsWith('.php') -and (Test-Path $fp)) { $phpExe = (Get-Command php -ErrorAction SilentlyContinue)?.Source; if ($phpExe) { & $phpExe -l $fp 2>&1 } } }\"",
            "timeout": 10000,
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -Command \"Add-Type -AssemblyName System.Windows.Forms; [System.Windows.Forms.MessageBox]::Show('Claude Code needs attention — ClearLegalTips', 'Claude Code', 'OK', 'Information')\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -Command \"Add-Content -Path 'C:/Users/fatih/Desktop(1)/Claude/clear_legal_tips/workspace/session-log.txt' -Value ((Get-Date -Format 'yyyy-MM-dd HH:mm') + ': Session ended')\"",
            "async": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -Command \"Add-Content -Path 'C:/Users/fatih/Desktop(1)/Claude/clear_legal_tips/workspace/agent-log.txt' -Value ((Get-Date -Format 'yyyy-MM-dd HH:mm') + ': Subagent completed')\"",
            "async": true
          }
        ]
      }
    ]
  }
}
